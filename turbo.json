{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": [
    "DATABASE_URL",
    "PGHOST",
    "PGPORT",
    "PGDATABASE",
    "PGUSER",
    "PGPASSWORD",
    "TOURNA_API_URL",
    "API_BASE_URL",
    "NODE_ENV",
    "REDIS_HOST",
    "REDIS_PORT",
    "REDIS_PASSWORD",
    "REDIS_DB",
    "WORKER_NOTIFICATIONS_CONCURRENCY",
    "WORKER_REPORTS_CONCURRENCY",
    "WORKER_RATINGS_CONCURRENCY",
    "WORKER_MAINTENANCE_CONCURRENCY",
    "WORKER_REGISTER_CRON"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "format": {
      "dependsOn": ["^format"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "test": {
      "dependsOn": ["^test"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"],
      "with": ["//#watch:packages"]
    },
    "dev:app": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    },
    "//#watch:packages": {
      "cache": false,
      "persistent": true
    },
    "watch": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["build"]
    },
    "migrate:up": {
      "cache": false,
      "dependsOn": ["^build"]
    },
    "migrate:down": {
      "cache": false,
      "dependsOn": ["^build"]
    },
    "migrate:status": {
      "cache": false
    }
  }
}
