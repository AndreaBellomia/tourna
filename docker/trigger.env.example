# Trigger.dev self-hosted Docker settings for Tourna.
# Copy to a private env file for production and replace every secret.

TRIGGER_IMAGE_TAG=v4-beta

TRIGGER_APP_ORIGIN=http://localhost:8030
TRIGGER_LOGIN_ORIGIN=http://localhost:8030
TRIGGER_API_ORIGIN=http://localhost:8030

# Do not use these defaults in production.
# Generate each value with: openssl rand -hex 16
TRIGGER_SESSION_SECRET=2818143646516f6fffd707b36f334bbb
TRIGGER_MAGIC_LINK_SECRET=44da78b7bbb0dfe709cf38931d25dcdd
TRIGGER_ENCRYPTION_KEY=f686147ab967943ebbe9ed3b496e465a
TRIGGER_MANAGED_WORKER_SECRET=447c29678f9eaf289e9c4b70d3dd8a7f

TRIGGER_POSTGRES_USER=postgres
TRIGGER_POSTGRES_PASSWORD=unsafe-postgres-pw
TRIGGER_POSTGRES_DB=postgres

TRIGGER_CLICKHOUSE_USER=default
TRIGGER_CLICKHOUSE_PASSWORD=password

TRIGGER_DOCKER_REGISTRY_URL=localhost:5000
TRIGGER_DOCKER_REGISTRY_NAMESPACE=trigger

TRIGGER_OBJECT_STORE_ACCESS_KEY_ID=admin
TRIGGER_OBJECT_STORE_SECRET_ACCESS_KEY=very-safe-password
