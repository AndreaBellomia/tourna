{
  "name": "@repo/contracts",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./auth": {
      "source": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./nest": {
      "source": "./src/nest.ts",
      "types": "./src/nest.ts",
      "default": "./dist/nest.js"
    }
  },
  "scripts": {
    "dev": "tsup src/index.ts src/nest.ts --dts --watch",
    "build": "tsup src/index.ts src/nest.ts --dts",
    "check-types": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write \"src/**/*.ts\" \"migrations/**/*.ts\""
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.15.3",
    "eslint": "^9.39.1",
    "prettier": "^3.4.2",
    "tsup": "^8.5.1",
    "typescript": "5.9.2"
  },
  "dependencies": {
    "nestjs-zod": "^5.4.0",
    "zod": "^4.4.3"
  }
}
