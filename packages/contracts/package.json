{
  "name": "@repo/contracts",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./auth": {
      "source": "./src/auth/index.ts",
      "types": "./src/auth/index.ts",
      "default": "./src/auth/index.ts"
    },
    "./pagination": {
      "source": "./src/pagination/index.ts",
      "types": "./src/pagination/index.ts",
      "default": "./src/pagination/index.ts"
    },
    "./profile": {
      "source": "./src/profile/index.ts",
      "types": "./src/profile/index.ts",
      "default": "./src/profile/index.ts"
    },
    "./storage": {
      "source": "./src/storage/index.ts",
      "types": "./src/storage/index.ts",
      "default": "./src/storage/index.ts"
    },
    "./team": {
      "source": "./src/team/index.ts",
      "types": "./src/team/index.ts",
      "default": "./src/team/index.ts"
    },
    "./nest": {
      "source": "./src/nest.ts",
      "types": "./src/nest.ts",
      "default": "./dist/nest.js"
    }
  },
  "scripts": {
    "watch": "tsup src/index.ts src/nest.ts --dts --watch",
    "build": "tsup src/index.ts src/nest.ts --dts",
    "check-types": "tsc --noEmit",
    "test": "pnpm --filter api exec jest --config ../../jest.packages.config.cjs --testPathPatterns packages/contracts/src/.*\\.spec\\.ts$ --passWithNoTests",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write \"src/**/*.ts\" \"migrations/**/*.ts\""
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.15.3",
    "eslint": "^9.39.1",
    "prettier": "^3.4.2",
    "tsup": "^8.5.1",
    "typescript": "5.9.2"
  },
  "dependencies": {
    "@repo/domain": "workspace:*",
    "nestjs-zod": "^5.4.0",
    "zod": "^4.4.3"
  }
}
