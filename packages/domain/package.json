{
  "name": "@repo/domain",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "watch": "tsdown src/index.ts --format cjs --no-dts --no-fixedExtension --watch",
    "build": "tsdown src/index.ts --format cjs --no-dts --no-fixedExtension && tsc --emitDeclarationOnly",
    "build:dev": "tsdown src/index.ts --format cjs --no-dts --no-fixedExtension --no-clean",
    "test": "pnpm --filter api exec jest --config ../../jest.packages.config.cjs --testPathPatterns packages/domain/src/.*\\.spec\\.ts$ --passWithNoTests",
    "check-types": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write \"src/**/*.ts\" \"migrations/**/*.ts\""
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.15.3",
    "eslint": "^9.39.1",
    "prettier": "^3.4.2"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
