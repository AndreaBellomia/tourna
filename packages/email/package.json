{
  "name": "@repo/email",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "repo-source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./contracts": {
      "repo-source": "./src/contracts.ts",
      "types": "./dist/contracts.d.ts",
      "default": "./dist/contracts.js"
    }
  },
  "scripts": {
    "watch": "tsup src/index.ts src/contracts.ts --dts --watch",
    "build": "tsup src/index.ts src/contracts.ts --dts",
    "check-types": "tsc --noEmit",
    "test": "NODE_OPTIONS=--experimental-vm-modules pnpm --filter api exec jest --config ../../jest.packages.config.cjs --testPathPatterns packages/email/src/.*\\.spec\\.ts$ --passWithNoTests",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx}\""
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.15.3",
    "@types/nodemailer": "^7.0.1",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "eslint": "^9.39.1",
    "prettier": "^3.4.2",
    "tsup": "^8.5.1",
    "typescript": "5.9.2"
  },
  "dependencies": {
    "i18next": "^26.3.0",
    "nodemailer": "^7.0.10",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-email": "^6.4.0",
    "zod": "^4.4.3"
  }
}
