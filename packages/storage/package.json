{
  "name": "@repo/storage",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "repo-source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "watch": "tsup src/index.ts --dts --watch",
    "build": "tsup src/index.ts --dts",
    "check-types": "tsc --noEmit",
    "test": "pnpm --filter api exec jest --config ../../jest.packages.config.cjs --testPathPatterns packages/storage/src/.*\\.spec\\.ts$ --passWithNoTests",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.15.3",
    "eslint": "^9.39.1",
    "prettier": "^3.4.2",
    "tsup": "^8.5.1",
    "typescript": "5.9.2"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.723.0",
    "@aws-sdk/s3-request-presigner": "3.723.0",
    "@repo/domain": "workspace:*",
    "@repo/redis": "workspace:*",
    "zod": "^4.4.3"
  }
}
