{
  "name": "@repo/db",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "watch": "tsup src/index.ts --dts --watch",
    "build": "tsup src/index.ts --dts",
    "check-types": "tsc --noEmit",
    "test": "pnpm --filter api exec jest --config ../../jest.packages.config.cjs --testPathPatterns packages/db/src/.*\\.spec\\.ts$ --passWithNoTests",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write \"src/**/*.ts\" \"migrations/**/*.ts\"",
    "migrate:up": "dotenv -e ../../.env -- kysely migrate latest",
    "migrate:down": "dotenv -e ../../.env -- kysely migrate down",
    "migrate:status": "dotenv -e ../../.env -- kysely migrate list",
    "migrate:step-up": "dotenv -e ../../.env -- kysely migrate up",
    "migration:create": "dotenv -e ../../.env -- kysely migrate make"
  },
  "devDependencies": {
    "@repo/domain": "workspace:*",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.15.3",
    "@types/pg": "^8.20.0",
    "dotenv-cli": "^7.1.0",
    "eslint": "^9.39.1",
    "kysely-ctl": "^0.21.0",
    "prettier": "^3.4.2",
    "tsup": "^8.5.1",
    "tsx": "^4.22.3",
    "typescript": "5.9.2"
  },
  "dependencies": {
    "kysely": "^0.29.2",
    "pg": "^8.21.0"
  }
}
