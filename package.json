{
  "name": "tourna",
  "private": true,
  "license": "PolyForm-Noncommercial-1.0.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=api --filter=web --filter=tasks --concurrency=12",
    "dev:api": "turbo run dev --filter=api",
    "dev:web": "turbo run dev --filter=web",
    "dev:tasks": "turbo run dev --filter=tasks",
    "dev:apps": "turbo run dev:app --filter=api --filter=web --filter=tasks --concurrency=12",
    "dev:api:app": "turbo run dev:app --filter=api",
    "dev:web:app": "turbo run dev:app --filter=web",
    "dev:tasks:app": "turbo run dev:app --filter=tasks",
    "infra:up": "docker compose -f docker/docker-compose.yml up -d",
    "infra:down": "docker compose -f docker/docker-compose.yml down",
    "infra:trigger:up": "docker compose -f docker/trigger-compose.yml up -d",
    "infra:trigger:down": "docker compose -f docker/trigger-compose.yml down",
    "infra:trigger:logs": "docker compose -f docker/trigger-compose.yml logs -f trigger-webapp trigger-supervisor",
    "infra:all:up": "docker compose -f docker/docker-compose.yml -f docker/trigger-compose.yml up -d",
    "infra:all:down": "docker compose -f docker/docker-compose.yml -f docker/trigger-compose.yml down",
    "watch:packages": "node scripts/watch-packages.mjs",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\" --ignore-path .prettierignore",
    "check-types": "turbo run check-types",
    "db:migrate:up": "turbo run migrate:up --filter=@repo/db",
    "db:migrate:down": "turbo run migrate:down --filter=@repo/db",
    "db:migrate:status": "turbo run migrate:status --filter=@repo/db",
    "db:migration:create": "pnpm --filter @repo/db migration:create"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.14",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "kysely": "^0.29.2",
    "pg": "^8.21.0"
  }
}
