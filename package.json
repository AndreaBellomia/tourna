{
  "name": "tourna",
  "private": true,
  "license": "PolyForm-Noncommercial-1.0.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=api --filter=web --filter=worker --concurrency=12",
    "dev:api": "turbo run dev --filter=api",
    "dev:web": "turbo run dev --filter=web",
    "dev:worker": "turbo run dev --filter=worker",
    "watch:packages": "turbo run watch --filter=@repo/authorization --filter=@repo/contracts --filter=@repo/db --filter=@repo/domain --filter=@repo/email --filter=@repo/queue --filter=@repo/redis --filter=@repo/storage",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\" --ignore-path .prettierignore",
    "check-types": "turbo run check-types",
    "db:migrate:up": "turbo run migrate:up --filter=@repo/db",
    "db:migrate:down": "turbo run migrate:down --filter=@repo/db",
    "db:migrate:status": "turbo run migrate:status --filter=@repo/db",
    "db:migration:create": "pnpm --filter @repo/db migration:create"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.14",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "kysely": "^0.29.2",
    "pg": "^8.21.0"
  }
}
