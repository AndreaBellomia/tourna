{
  "name": "tasks",
  "version": "0.0.1",
  "description": "Tourna Trigger.dev task runtime",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "dev": "TRIGGER_API_URL=${TRIGGER_API_URL:-http://localhost:8030} TRIGGER_PROJECT_REF=${TRIGGER_PROJECT_REF:-proj_juorqpgdlhipsiicxnks} trigger dev --api-url ${TRIGGER_API_URL:-http://localhost:8030} --project-ref ${TRIGGER_PROJECT_REF:-proj_juorqpgdlhipsiicxnks} --profile ${TRIGGER_PROFILE:-self-hosted}",
    "dev:app": "pnpm run dev",
    "build": "tsc --noEmit",
    "start": "pnpm run dev",
    "login:self-hosted": "TRIGGER_API_URL=${TRIGGER_API_URL:-http://localhost:8030} trigger login --api-url ${TRIGGER_API_URL:-http://localhost:8030} --profile ${TRIGGER_PROFILE:-self-hosted}",
    "whoami:self-hosted": "TRIGGER_API_URL=${TRIGGER_API_URL:-http://localhost:8030} trigger whoami --profile ${TRIGGER_PROFILE:-self-hosted}",
    "deploy:self-hosted": "TRIGGER_API_URL=${TRIGGER_API_URL:-http://localhost:8030} TRIGGER_PROJECT_REF=${TRIGGER_PROJECT_REF:-proj_juorqpgdlhipsiicxnks} trigger deploy --api-url ${TRIGGER_API_URL:-http://localhost:8030} --project-ref ${TRIGGER_PROJECT_REF:-proj_juorqpgdlhipsiicxnks} --profile ${TRIGGER_PROFILE:-self-hosted} --local-build",
    "deploy:self-hosted:dry-run": "TRIGGER_API_URL=${TRIGGER_API_URL:-http://localhost:8030} TRIGGER_PROJECT_REF=${TRIGGER_PROJECT_REF:-proj_juorqpgdlhipsiicxnks} trigger deploy --dry-run --api-url ${TRIGGER_API_URL:-http://localhost:8030} --project-ref ${TRIGGER_PROJECT_REF:-proj_juorqpgdlhipsiicxnks} --profile ${TRIGGER_PROFILE:-self-hosted} --local-build",
    "lint": "eslint \"src/**/*.ts\" \"trigger/**/*.ts\" \"trigger.config.ts\"",
    "format": "prettier --write \"src/**/*.ts\"",
    "check-types": "tsc --noEmit",
    "test": "jest"
  },
  "dependencies": {
    "@repo/email": "workspace:*",
    "@repo/redis": "workspace:*",
    "@repo/storage": "workspace:*",
    "@repo/tasks": "workspace:*",
    "@trigger.dev/sdk": "4.4.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "eslint": "^9.18.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "trigger.dev": "4.4.6",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^~$": "<rootDir>/src",
      "^~/(.*)$": "<rootDir>/src/$1"
    }
  }
}
