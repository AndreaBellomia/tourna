{
  "extends": "@repo/typescript-config/base.json",
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "customConditions": ["repo-source"],
    "jsx": "react-jsx",
    "target": "ES2023",
    "sourceMap": true,
    "incremental": true,
    "types": ["jest", "node"],
    "baseUrl": "./",
    "paths": {
      "~": ["src"],
      "~/*": ["src/*"]
    },
    "noEmit": true
  }
}
