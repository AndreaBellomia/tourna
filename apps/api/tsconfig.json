{
  "extends": "@repo/typescript-config/nestjs.json",
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "customConditions": [
      "source"
    ],
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "incremental": true,
    "types": [
      "jest",
      "node"
    ],
    "baseUrl": "./",
    "paths": {
      "@app/shared": [
        "libs/shared/src"
      ],
      "@app/shared/*": [
        "libs/shared/src/*"
      ]
    }
  }
}