{
  "jsc": {
    "target": "es2021",
    "baseUrl": ".",
    "paths": {
      "~": ["src"],
      "~/*": ["src/*"]
    },
    "parser": {
      "syntax": "typescript",
      "decorators": true
    },
    "transform": {
      "legacyDecorator": true,
      "decoratorMetadata": true
    }
  },
  "module": {
    "type": "commonjs"
  }
}
